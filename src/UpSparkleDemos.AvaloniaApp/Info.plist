<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle identity — required by Sparkle for update checking -->
    <key>CFBundleIdentifier</key>
    <string>com.upsparkle.avalonia-demo</string>

    <key>CFBundleName</key>
    <string>UpSparkle Avalonia Demo</string>

    <key>CFBundleDisplayName</key>
    <string>UpSparkle Avalonia Demo</string>

    <!-- CFBundleShortVersionString + CFBundleVersion are required by Sparkle -->
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleExecutable</key>
    <string>UpSparkleDemos.AvaloniaApp</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- Sparkle 2: appcast URL (can be overridden at runtime via setFeedURL:) -->
    <key>SUFeedURL</key>
    <string>https://sparkle-project.org/files/sparkletestcast.xml</string>

    <!-- Sparkle 2: EdDSA public key — REQUIRED, updater will refuse to start without it.
         Replace with the real key generated by generate_keys from Sparkle's bin/ directory. -->
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_YOUR_EDDSA_PUBLIC_KEY</string>

    <!-- Allow Sparkle to show a permission prompt on first launch -->
    <key>SUEnableAutomaticChecks</key>
    <false/>

    <key>NSHighResolutionCapable</key>
    <true/>

    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
</dict>
</plist>
